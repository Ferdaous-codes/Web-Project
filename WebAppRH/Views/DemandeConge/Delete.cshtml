@model WebAppRH.Models.DemandeConge
@using WebAppRH.Models

@{
    ViewData["Title"] = "Supprimer une demande de congé";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4 text-danger">⚠️ Confirmer la suppression</h2>

        <div class="alert alert-warning">
            <strong>Attention :</strong> Cette action est irréversible.
        </div>

        <table class="table">
            <tr>
                <th style="width: 35%;">Date de début</th>
                <td>@Model.DateDebut.ToShortDateString()</td>
            </tr>
            <tr>
                <th>Date de fin</th>
                <td>@Model.DateFin.ToShortDateString()</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>
                    @switch (Model.Type)
                    {
                        case TypeConge.Annuel:
                            <span class="badge bg-info">Annuel</span>
                            break;
                        case TypeConge.Maladie:
                            <span class="badge bg-warning text-dark">Maladie</span>
                            break;
                        case TypeConge.SansSolde:
                            <span class="badge bg-secondary">Sans Solde</span>
                            break;
                    }
                </td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>
                    <span class="badge bg-warning text-dark">En attente</span>
                </td>
            </tr>
            <tr>
                <th>Soumise le</th>
                <td>@Model.DateSoumission.ToShortDateString()</td>
            </tr>
        </table>

        <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger w-100">
                🗑️ Confirmer la suppression
            </button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
        </form>
    </div>
</div>