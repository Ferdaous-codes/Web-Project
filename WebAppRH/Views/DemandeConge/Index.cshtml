@model IEnumerable<WebAppRH.Models.DemandeConge>
@using WebAppRH.Models

@{
    ViewData["Title"] = "Liste des Demandes de Congé";
    var isManager = User.IsInRole("Manager");
    var isEmploye = User.IsInRole("Employe");
}

<h2 class="mb-4">Demandes de Congé</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (isEmploye)
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Nouvelle demande</a>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Aucune demande à afficher.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Employé</th>
                <th>Date Début</th>
                <th>Date Fin</th>
                <th>Type</th>
                <th>Statut</th>
                <th>Soumise le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td>@d.Employe?.Prenom @d.Employe?.Nom</td>
                    <td>@d.DateDebut.ToShortDateString()</td>
                    <td>@d.DateFin.ToShortDateString()</td>
                    <td>
                        @switch (d.Type)
                        {
                            case TypeConge.Annuel:
                                <span class="badge bg-info">Annuel</span>
                                break;
                            case TypeConge.Maladie:
                                <span class="badge bg-warning text-dark">Maladie</span>
                                break;
                            case TypeConge.SansSolde:
                                <span class="badge bg-secondary">Sans Solde</span>
                                break;
                        }
                    </td>
                    <td>
                        @switch (d.Statut)
                        {
                            case StatutConge.EnAttente:
                                <span class="badge bg-warning text-dark">En attente</span>
                                break;
                            case StatutConge.Approuve:
                                <span class="badge bg-success">Approuvé</span>
                                break;
                            case StatutConge.Refuse:
                                <span class="badge bg-danger">Refusé</span>
                                break;
                        }
                    </td>
                    <td>@d.DateSoumission.ToShortDateString()</td>
                    <td>
                        @* Actions Employé : modifier/supprimer ses demandes en attente *@
                        @if (isEmploye && d.Statut == StatutConge.EnAttente)
                        {
                            <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary">Modifier</a>
                            <a asp-action="Delete" asp-route-id="@d.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                        }

                        @* Actions Manager : approuver/refuser via POST *@
                        @if (isManager && d.Statut == StatutConge.EnAttente)
                        {
                            <form method="post" asp-action="Approuver" asp-route-id="@d.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success"
                                        onclick="return confirm('Approuver cette demande ?');">
                                    ✓ Approuver
                                </button>
                            </form>

                            <button type="button" class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal" data-bs-target="#refuserModal-@d.Id">
                                ✗ Refuser
                            </button>

                            @* Modal de saisie du motif de refus *@
                            <div class="modal fade" id="refuserModal-@d.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form method="post" asp-action="Refuser" asp-route-id="@d.Id">
                                            @Html.AntiForgeryToken()
                                            <div class="modal-header">
                                                <h5 class="modal-title">Refuser la demande</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <label class="form-label">Motif du refus</label>
                                                <textarea name="motif" class="form-control" rows="3" required></textarea>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                                <button type="submit" class="btn btn-danger">Confirmer le refus</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (d.Statut == StatutConge.Refuse && !string.IsNullOrEmpty(d.MotifRefus))
                        {
                            <small class="text-muted d-block mt-1" title="@d.MotifRefus">
                                💬 Motif: @(d.MotifRefus.Length > 30 ? d.MotifRefus.Substring(0, 30) + "..." : d.MotifRefus)
                            </small>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}