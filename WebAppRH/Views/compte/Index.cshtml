@model WebAppRH.Models.Utilisateur

@{
    ViewData["Title"] = "Mon Compte";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <h2 class="mb-4">⚙️ Mon Compte</h2>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">👤 Informations personnelles</h5>
                <a asp-action="ModifierProfil" class="btn btn-light btn-sm">✏️ Modifier</a>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">ID</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary">#@Model.Id</span>
                    </dd>

                    <dt class="col-sm-3">Nom</dt>
                    <dd class="col-sm-9">@Model.Nom</dd>

                    <dt class="col-sm-3">Prénom</dt>
                    <dd class="col-sm-9">@Model.Prenom</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Rôle</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary">@role</span>
                    </dd>

                    <dt class="col-sm-3">Statut du compte</dt>
                    <dd class="col-sm-9">
                        @if (Model.Compte?.Actif == true)
                        {
                            <span class="badge bg-success">Actif</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactif</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0">🔒 Sécurité</h5>
                <a asp-action="ChangerMotDePasse" class="btn btn-dark btn-sm">Changer le mot de passe</a>
            </div>
            <div class="card-body">
                <p class="mb-0 text-muted">
                    Pour la sécurité de votre compte, il est recommandé de changer régulièrement votre mot de passe.
                </p>
            </div>
        </div>
    </div>
</div>