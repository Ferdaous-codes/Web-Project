@{
    ViewData["Title"] = "Changer mon mot de passe";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">🔒 Changer mon mot de passe</h2>

        @if (ViewBag.Erreur != null)
        {
            <div class="alert alert-danger">@ViewBag.Erreur</div>
        }

        <form method="post" asp-action="ChangerMotDePasse">
            @Html.AntiForgeryToken()

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Mot de passe actuel</label>
                        <input type="password" name="motDePasseActuel" class="form-control" required />
                    </div>

                    <hr />

                    <div class="mb-3">
                        <label class="form-label">Nouveau mot de passe</label>
                        <input type="password" name="nouveauMotDePasse" class="form-control" minlength="6" required />
                        <small class="form-text text-muted">Minimum 6 caractères.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirmer le nouveau mot de passe</label>
                        <input type="password" name="confirmation" class="form-control" minlength="6" required />
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <small>
                    💡 <strong>Conseils pour un bon mot de passe :</strong> au moins 8 caractères, mélangez
                    majuscules, minuscules, chiffres et caractères spéciaux.
                </small>
            </div>

            <button type="submit" class="btn btn-primary w-100">Confirmer le changement</button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
        </form>
    </div>
</div>