@model WebAppRH.Models.Departement

@{
    ViewData["Title"] = "Supprimer un département";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4 text-danger">⚠️ Confirmer la suppression</h2>

        <div class="alert alert-warning">
            <strong>Attention :</strong> Cette action est irréversible.
        </div>

        <table class="table">
            <tr>
                <th style="width: 30%;">Nom</th>
                <td>@Model.Nom</td>
            </tr>
            <tr>
                <th>Budget</th>
                <td>@Model.Budget.ToString("N2") TND</td>
            </tr>
            <tr>
                <th>Responsable</th>
                <td>
                    @if (Model.Responsable != null)
                    {
                        <span>@Model.Responsable.Prenom @Model.Responsable.Nom</span>
                    }
                    else
                    {
                        <span class="text-muted">Non assigné</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Nombre d'employés</th>
                <td>@Model.Employes.Count</td>
            </tr>
        </table>

        @if (Model.Employes.Any())
        {
            <div class="alert alert-danger">
                ⛔ Ce département contient <strong>@Model.Employes.Count employé(s)</strong>.
                Vous devez d'abord les transférer vers un autre département.
            </div>
            <a asp-action="Index" class="btn btn-secondary w-100">Retour à la liste</a>
        }
        else
        {
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger w-100">
                    🗑️ Confirmer la suppression
                </button>
                <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
            </form>
        }
    </div>
</div>