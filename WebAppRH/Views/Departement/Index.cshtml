@model IEnumerable<WebAppRH.Models.Departement>

@{
    ViewData["Title"] = "Liste des Départements";
    var isAdmin = User.IsInRole("Administrateur");
}

<h2 class="mb-4">Départements</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Erreur"] != null)
{
    <div class="alert alert-danger">@TempData["Erreur"]</div>
}

@if (isAdmin)
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Ajouter un département</a>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Aucun département à afficher.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Budget</th>
                <th>Responsable</th>
                <th>Nb Employés</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td><strong>@d.Nom</strong></td>
                    <td>@d.Budget.ToString("N2") TND</td>
                    <td>
                        @if (d.Responsable != null)
                        {
                            <span>@d.Responsable.Prenom @d.Responsable.Nom</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Non assigné</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-info">@d.Employes.Count</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@d.Id"
                           class="btn btn-sm btn-outline-info">Détails</a>

                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@d.Id"
                               class="btn btn-sm btn-outline-primary">Modifier</a>

                            <a asp-action="Delete" asp-route-id="@d.Id"
                               class="btn btn-sm btn-outline-danger">Supprimer</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}