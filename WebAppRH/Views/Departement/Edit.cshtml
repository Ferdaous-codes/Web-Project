@model WebAppRH.Models.Departement

@{
    ViewData["Title"] = "Modifier un département";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">Modifier le département</h2>

        <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Nom du département</label>
                <input type="text" name="Nom" value="@Model.Nom"
                       class="form-control" required maxlength="100" />
            </div>

            <div class="mb-3">
                <label class="form-label">Budget (TND)</label>
                <input type="number" name="Budget" value="@Model.Budget"
                       class="form-control" step="0.01" min="0" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Responsable</label>
                <select name="ResponsableId" class="form-control">
                    <option value="">-- Aucun responsable --</option>
                    @if (ViewBag.Managers != null)
                    {
                        @foreach (var m in ViewBag.Managers)
                        {
                            if (m.Id == Model.ResponsableId)
                            {
                                <option value="@m.Id" selected>@m.Prenom @m.Nom</option>
                            }
                            else
                            {
                                <option value="@m.Id">@m.Prenom @m.Nom</option>
                            }
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100">Enregistrer les modifications</button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
        </form>
    </div>
</div>