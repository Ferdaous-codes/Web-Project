@model WebAppRH.Models.Departement

@{
    ViewData["Title"] = "Ajouter un département";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">Ajouter un département</h2>

        <form method="post" asp-action="Create">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Nom du département</label>
                <input type="text" name="Nom" class="form-control" required maxlength="100" />
            </div>

            <div class="mb-3">
                <label class="form-label">Budget (TND)</label>
                <input type="number" name="Budget" class="form-control"
                       step="0.01" min="0" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Responsable (optionnel)</label>
                <select name="ResponsableId" class="form-control">
                    <option value="">-- Aucun responsable pour l'instant --</option>
                    @if (ViewBag.Managers != null)
                    {
                        @foreach (var m in ViewBag.Managers)
                        {
                            <option value="@m.Id">@m.Prenom @m.Nom</option>
                        }
                    }
                </select>
                <small class="form-text text-muted">
                    Seuls les managers sans département actuel sont listés.
                </small>
            </div>

            <button type="submit" class="btn btn-primary w-100">Créer le département</button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
        </form>
    </div>
</div>