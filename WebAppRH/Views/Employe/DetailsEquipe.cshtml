@model WebAppRH.Models.Employe
@using WebAppRH.Models

@{
    ViewData["Title"] = "Détails - " + Model.Prenom + " " + Model.Nom;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>👤 @Model.Prenom @Model.Nom</h2>
            <a asp-action="MonEquipe" class="btn btn-secondary">← Retour à mon équipe</a>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Informations</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">ID</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary">#@Model.Id</span>
                    </dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Poste</dt>
                    <dd class="col-sm-9">@Model.Poste</dd>

                    <dt class="col-sm-3">Département</dt>
                    <dd class="col-sm-9">@(Model.Departement?.Nom ?? "Non assigné")</dd>

                    <dt class="col-sm-3">Solde de congés</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-info fs-6">@Model.SoldeConge jours</span>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">Historique des demandes de congé</h5>
            </div>
            <div class="card-body">
                @if (Model.DemandesConge.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Date Début</th>
                                <th>Date Fin</th>
                                <th>Type</th>
                                <th>Statut</th>
                                <th>Soumise le</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.DemandesConge.OrderByDescending(x => x.DateSoumission))
                            {
                                <tr>
                                    <td>@d.DateDebut.ToShortDateString()</td>
                                    <td>@d.DateFin.ToShortDateString()</td>
                                    <td>
                                        @switch (d.Type)
                                        {
                                            case TypeConge.Annuel:
                                                <span class="badge bg-info">Annuel</span>
                                                break;
                                            case TypeConge.Maladie:
                                                <span class="badge bg-warning text-dark">Maladie</span>
                                                break;
                                            case TypeConge.SansSolde:
                                                <span class="badge bg-secondary">Sans Solde</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (d.Statut)
                                        {
                                            case StatutConge.EnAttente:
                                                <span class="badge bg-warning text-dark">En attente</span>
                                                break;
                                            case StatutConge.Approuve:
                                                <span class="badge bg-success">Approuvé</span>
                                                break;
                                            case StatutConge.Refuse:
                                                <span class="badge bg-danger">Refusé</span>
                                                break;
                                        }
                                    </td>
                                    <td>@d.DateSoumission.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        Aucune demande de congé pour cet employé.
                    </div>
                }
            </div>
        </div>
    </div>
</div>