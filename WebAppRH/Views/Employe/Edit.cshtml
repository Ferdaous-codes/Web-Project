@model WebAppRH.Models.Employe

@{
    ViewData["Title"] = "Modifier un employé";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">Modifier l'employé</h2>

        <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="MotDePasseHash" value="@Model.MotDePasseHash" />

            <div class="mb-3">
                <label class="form-label">Nom</label>
                <input type="text" name="Nom" value="@Model.Nom" class="form-control" required maxlength="100" />
            </div>

            <div class="mb-3">
                <label class="form-label">Prénom</label>
                <input type="text" name="Prenom" value="@Model.Prenom" class="form-control" required maxlength="100" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="Email" value="@Model.Email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Poste</label>
                <input type="text" name="Poste" value="@Model.Poste" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Solde de congés (jours)</label>
                <input type="number" name="SoldeConge" value="@Model.SoldeConge" class="form-control" min="0" max="365" />
            </div>

            <div class="mb-3">
                <label class="form-label">Département</label>
                <select name="DepartementId" class="form-control">
                    <option value="">-- Aucun département --</option>
                    @if (ViewBag.Departements != null)
                    {
                        @foreach (var d in ViewBag.Departements)
                        {
                            if (d.Id == Model.DepartementId)
                            {
                                <option value="@d.Id" selected>@d.Nom</option>
                            }
                            else
                            {
                                <option value="@d.Id">@d.Nom</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Manager</label>
                <select name="ManagerId" class="form-control">
                    <option value="">-- Aucun manager --</option>
                    @if (ViewBag.Managers != null)
                    {
                        @foreach (var m in ViewBag.Managers)
                        {
                            if (m.Id == Model.ManagerId)
                            {
                                <option value="@m.Id" selected>@m.Prenom @m.Nom</option>
                            }
                            else
                            {
                                <option value="@m.Id">@m.Prenom @m.Nom</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="alert alert-info">
                <small>
                    📌 Pour des raisons de sécurité, le mot de passe ne peut pas être modifié depuis cette page.
                    Si l'employé souhaite changer son mot de passe, il doit le faire lui-même via
                    son espace <strong>"Mon Compte"</strong>.
                </small>
            </div>

            <button type="submit" class="btn btn-primary w-100">Enregistrer les modifications</button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
        </form>
    </div>
</div>