@model IEnumerable<WebAppRH.Models.Employe>
@using WebAppRH.Models

@{
    ViewData["Title"] = "Mon Équipe";
    var manager = ViewBag.Manager as Manager;
}

<div class="row mb-4">
    <div class="col">
        <h2>👥 Mon Équipe</h2>
        @if (manager?.Departement != null)
        {
            <p class="text-muted">
                Département : <strong>@manager.Departement.Nom</strong>
            </p>
        }
    </div>
    <div class="col-auto">
        <span class="badge bg-primary fs-6">@Model.Count() membre(s)</span>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Aucun employé ne vous est rattaché pour le moment.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var e in Model)
        {
            var demandesEnAttente = e.DemandesConge.Count(d => d.Statut == StatutConge.EnAttente);
            var demandesApprouvees = e.DemandesConge.Count(d => d.Statut == StatutConge.Approuve);

            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">@e.Prenom @e.Nom</h5>
                            <small class="text-muted">ID: <span class="badge bg-secondary">#@e.Id</span></small>
                        </div>
                        @if (demandesEnAttente > 0)
                        {
                            <span class="badge bg-warning text-dark">
                                @demandesEnAttente demande(s) en attente
                            </span>
                        }
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless table-sm mb-3">
                            <tr>
                                <th style="width: 40%;">Email</th>
                                <td>@e.Email</td>
                            </tr>
                            <tr>
                                <th>Poste</th>
                                <td>@e.Poste</td>
                            </tr>
                            <tr>
                                <th>Département</th>
                                <td>@(e.Departement?.Nom ?? "—")</td>
                            </tr>
                            <tr>
                                <th>Solde de congés</th>
                                <td><span class="badge bg-info">@e.SoldeConge jours</span></td>
                            </tr>
                            <tr>
                                <th>Demandes approuvées</th>
                                <td>@demandesApprouvees</td>
                            </tr>
                        </table>

                        <a asp-action="DetailsEquipe" asp-route-id="@e.Id"
                               class="btn btn-sm btn-outline-primary w-100">
                            Voir les détails
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}