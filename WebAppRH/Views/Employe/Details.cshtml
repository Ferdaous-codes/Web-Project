@model WebAppRH.Models.Employe
@using WebAppRH.Models

@{
    ViewData["Title"] = "Détails employé";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <h2 class="mb-4">Détails de l'employé</h2>

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@Model.Prenom @Model.Nom</h4>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th style="width: 30%;">ID</th>
                        <td><span class="badge bg-secondary">#@Model.Id</span></td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <th>Poste</th>
                        <td>@Model.Poste</td>
                    </tr>
                    <tr>
                        <th>Département</th>
                        <td>
                            @if (Model.Departement != null)
                            {
                                @Model.Departement.Nom
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Non assigné</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Manager</th>
                        <td>
                            @if (Model.Manager != null)
                            {
                                @Model.Manager.Prenom
                                @Model.Manager.Nom
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Non assigné</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Solde de congés</th>
                        <td>
                            <span class="badge bg-info fs-6">@Model.SoldeConge jours</span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <h4>Demandes de congé</h4>
        @if (Model.DemandesConge.Any())
        {
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Date Début</th>
                        <th>Date Fin</th>
                        <th>Type</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.DemandesConge.OrderByDescending(x => x.DateSoumission))
                    {
                        <tr>
                            <td>@d.DateDebut.ToShortDateString()</td>
                            <td>@d.DateFin.ToShortDateString()</td>
                            <td>
                                @switch (d.Type)
                                {
                                    case TypeConge.Annuel:
                                        <span class="badge bg-info">Annuel</span>
                                        break;
                                    case TypeConge.Maladie:
                                        <span class="badge bg-warning text-dark">Maladie</span>
                                        break;
                                    case TypeConge.SansSolde:
                                        <span class="badge bg-secondary">Sans Solde</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (d.Statut)
                                {
                                    case StatutConge.EnAttente:
                                        <span class="badge bg-warning text-dark">En attente</span>
                                        break;
                                    case StatutConge.Approuve:
                                        <span class="badge bg-success">Approuvé</span>
                                        break;
                                    case StatutConge.Refuse:
                                        <span class="badge bg-danger">Refusé</span>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info">Aucune demande de congé.</div>
        }

        <div class="mt-4">
            <a asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
            @if (User.IsInRole("Administrateur"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
            }
        </div>
    </div>
</div>