@model WebAppRH.Models.Manager

@{
    ViewData["Title"] = "Supprimer un manager";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4 text-danger">⚠️ Confirmer la suppression</h2>

        <div class="alert alert-warning">
            <strong>Attention :</strong> Cette action est irréversible.
        </div>

        <table class="table">
            <tr>
                <th style="width: 30%;">Nom complet</th>
                <td>@Model.Prenom @Model.Nom</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <th>Département supervisé</th>
                <td>@(Model.Departement?.Nom ?? "Aucun")</td>
            </tr>
            <tr>
                <th>Nombre d'employés sous sa responsabilité</th>
                <td>@Model.Equipe.Count</td>
            </tr>
        </table>

        @if (Model.Equipe.Any())
        {
            <div class="alert alert-danger">
                ⛔ Ce manager supervise <strong>@Model.Equipe.Count employé(s)</strong>.
                Vous devez d'abord les réassigner à un autre manager.
            </div>
            <a asp-action="Index" class="btn btn-secondary w-100">Retour à la liste</a>
        }
        else
        {
            <form method="post" asp-action="DeleteManager" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger w-100">
                    🗑️ Confirmer la suppression
                </button>
                <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
            </form>
        }
    </div>
</div>