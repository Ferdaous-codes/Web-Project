@model WebAppRH.Models.Manager

@{
    ViewData["Title"] = "Modifier un manager";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">Modifier le manager</h2>

        <form method="post" asp-action="EditManager" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()

            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Nom</label>
                <input type="text" name="nom" value="@Model.Nom" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Prénom</label>
                <input type="text" name="prenom" value="@Model.Prenom" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" value="@Model.Email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Département supervisé</label>
                <select name="departementId" class="form-control">
                    <option value="">-- Aucun --</option>
                    @if (ViewBag.Departements != null)
                    {
                        @foreach (var d in ViewBag.Departements)
                        {
                            if (Model.Departement != null && d.Id == Model.Departement.Id)
                            {
                                <option value="@d.Id" selected>@d.Nom</option>
                            }
                            else
                            {
                                <option value="@d.Id">@d.Nom</option>
                            }
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100">Enregistrer</button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Annuler</a>
        </form>
    </div>
</div>