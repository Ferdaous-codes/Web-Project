@model ErrorViewModel

@{
    ViewData["Title"] = "Erreur";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="alert alert-danger">
            <h1 class="display-4 text-danger">⚠️ Erreur</h1>
            <h2 class="mb-3">Une erreur est survenue lors du traitement de votre requête.</h2>

            @if (Model.ShowRequestId)
            {
                <p class="mb-0">
                    <strong>Identifiant de requête :</strong> <code>@Model.RequestId</code>
                </p>
            }
        </div>

        <div class="mt-4">
            <h3>Mode développement</h3>
            <p>
                Le passage à l'environnement <strong>Development</strong> affiche des informations
                détaillées sur les erreurs survenues.
            </p>
            <p>
                <strong>L'environnement Development ne devrait pas être activé pour les applications déployées.</strong>
                Cela peut entraîner l'affichage d'informations sensibles aux utilisateurs finaux.
                Pour le débogage local, vous pouvez activer l'environnement <em>Development</em>
                en définissant la variable d'environnement <code>ASPNETCORE_ENVIRONMENT</code> sur <code>Development</code>
                et en redémarrant l'application.
            </p>
        </div>

        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                ← Retour à l'accueil
            </a>
        </div>
    </div>
</div>