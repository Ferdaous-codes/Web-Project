<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebAppRH</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebAppRH.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">WebAppRH</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>

                        @if (User.IsInRole("Administrateur"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Employe" asp-action="Index">Utilisateurs</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Departement" asp-action="Index">Départements</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Compte" asp-action="Index">Mon Compte</a>
                            </li>
                        }

                        @if (User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Employe" asp-action="MonEquipe">Mon Équipe</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="DemandeConge" asp-action="Index">Congés de l'équipe</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Departement" asp-action="Index">Départements</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Compte" asp-action="Index">Mon Compte</a>
                            </li>
                        }

                        @if (User.IsInRole("Employe"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="DemandeConge" asp-action="Index">Mes Congés</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Compte" asp-action="Index">Mon Compte</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var prenom = User.FindFirst("Prenom")?.Value ?? User.Identity.Name;
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    👤 <strong>@prenom</strong> <small class="text-muted">(@role)</small>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark border-0">
                                        Déconnexion
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Connexion</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["Erreur"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Erreur"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebAppRH - <a asp-controller="Home" asp-action="Privacy">Confidentialité</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>