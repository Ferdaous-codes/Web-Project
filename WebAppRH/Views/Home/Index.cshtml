@{
    ViewData["Title"] = "Accueil";
}

<div class="text-center">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var prenom = User.FindFirst("Prenom")?.Value ?? "";

        <div class="mt-4">
            <h1 class="display-4">Bonjour, @prenom 👋</h1>
            <p class="lead text-muted">Bienvenue sur votre espace de gestion RH</p>
        </div>

        <div class="row mt-5 g-4 justify-content-center">
            @if (User.IsInRole("Administrateur"))
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">👥</div>
                            <h5 class="card-title">Utilisateurs</h5>
                            <p class="card-text text-muted">Gérer les employés et managers</p>
                            <a asp-controller="Employe" asp-action="Index" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">🏢</div>
                            <h5 class="card-title">Départements</h5>
                            <p class="card-text text-muted">Organiser les départements</p>
                            <a asp-controller="Departement" asp-action="Index" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>
            }
            else if (User.IsInRole("Manager"))
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">👥</div>
                            <h5 class="card-title">Mon Équipe</h5>
                            <p class="card-text text-muted">Voir mes employés</p>
                            <a asp-controller="Employe" asp-action="MonEquipe" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">📋</div>
                            <h5 class="card-title">Demandes de congé</h5>
                            <p class="card-text text-muted">Approuver ou refuser</p>
                            <a asp-controller="DemandeConge" asp-action="Index" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">🏢</div>
                            <h5 class="card-title">Départements</h5>
                            <p class="card-text text-muted">Consulter les départements</p>
                            <a asp-controller="Departement" asp-action="Index" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>
            }
            else if (User.IsInRole("Employe"))
            {
                <div class="col-md-5">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">📅</div>
                            <h5 class="card-title">Mes demandes de congé</h5>
                            <p class="card-text text-muted">Consulter et soumettre des demandes</p>
                            <a asp-controller="DemandeConge" asp-action="Index" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="display-1 mb-3">⚙️</div>
                            <h5 class="card-title">Mon Compte</h5>
                            <p class="card-text text-muted">Gérer mes informations</p>
                            <a asp-controller="Account" asp-action="MonCompte" class="btn btn-primary">Accéder</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="mt-5">
            <h1 class="display-4">WebAppRH</h1>
            <p class="lead text-muted">Plateforme de gestion des ressources humaines</p>

            <div class="row mt-5 g-4 justify-content-center">
                <div class="col-md-3">
                    <div class="text-center">
                        <div class="display-3">🔐</div>
                        <h5 class="mt-2">Sécurisé</h5>
                        <p class="text-muted small">Authentification par rôle</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center">
                        <div class="display-3">⚡</div>
                        <h5 class="mt-2">Rapide</h5>
                        <p class="text-muted small">Gestion des congés simplifiée</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center">
                        <div class="display-3">📊</div>
                        <h5 class="mt-2">Organisé</h5>
                        <p class="text-muted small">Suivi des employés et départements</p>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                    Se connecter
                </a>
            </div>

            <div class="mt-4 text-muted">
                <small>
                    Vous n'avez pas de compte ? Contactez votre administrateur RH.
                </small>
            </div>
        </div>
    }
</div>